<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C8C8C8"
    android:orientation="vertical"
    android:keepScreenOn="true">

    <!-- Scrollable content fills remaining space -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="15dp"
            android:paddingTop="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="50dp"
                android:background="#F6F6F6"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="30dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Important:"
                    android:textColor="#141414"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="To maintain a stable connection, address must not change. If you are using the IP and it is dynamic, the player will restart and become inaccessible when the IP changes."
                    android:textColor="#343434"
                    android:textSize="24sp" />


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="If you lose connection:"
                    android:textColor="#141414"
                    android:textSize="24sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Find the new address on the player's display or in your router's device list.  For best results, set a Static IP for this player in your router settings."
                    android:textColor="#343434"
                    android:textSize="24sp" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="50dp"
                android:background="#F6F6F6"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="30dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PORT"
                        android:textColor="#070707"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginRight="16dp" />

                    <EditText
                        android:id="@+id/portInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ems="10"
                        android:inputType="number"
                        android:textColor="#000000"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <Button
                    android:id="@+id/portSet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SET"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/portInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:text="⚠️ Set port for start ⚠️"
                    android:textColor="#070707"
                    android:textSize="24sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:text="example: 8080 - 10000"
                    android:textColor="#070707"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:text="Please set the required port and ensure no other device (like embplayer) is using it on the same port on network to avoid conflicts."
                    android:textColor="#070707"
                    android:textSize="24sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="50dp"
                android:background="#F6F6F6"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="30dp">

                <Switch
                    android:id="@+id/autoStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-start"
                    android:textColor="#070707"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Auto-start helps keep the app running after reboot."
                    android:textColor="#070707"
                    android:textSize="24sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F6F6F6"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="30dp">

                <Button
                    android:id="@+id/battery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Battery"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/batteryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Battery restrictions may affect app performance.
Features like auto-start, notifications, or background tasks may not work correctly.
Please disable battery optimizations for this app in your device settings."
                    android:textColor="#070707"
                    android:textSize="24sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom button stays visible and compact -->
    <LinearLayout
        android:id="@+id/portIfNotNull"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#909090"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <Button
            android:id="@+id/close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:enabled="false"
            android:text="To Player"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>
